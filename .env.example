# =============================================================================
# reelsbot 환경변수 설정
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요.
#   cp .env.example .env
# =============================================================================

# ── AI ────────────────────────────────────────────────────────────────────────

# Google AI Studio API 키 (Gemini 1.5 Pro 영상 분석 + Gemini 2.5 Pro TTS)
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic API 키 (Claude claude-sonnet-4-20250514 스크립트 생성)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── 데이터베이스 (PostgreSQL) ──────────────────────────────────────────────────
# docker-compose 사용 시 아래 기본값 유지 (db 서비스 호스트명 사용)
# 로컬 직접 실행 시: postgresql+asyncpg://reelsbot:reelsbot@localhost:5432/reelsbot
DATABASE_URL=postgresql+asyncpg://reelsbot:reelsbot@db:5432/reelsbot

# ── Redis / Celery ─────────────────────────────────────────────────────────────
# docker-compose 사용 시 아래 기본값 유지
# 로컬 직접 실행 시: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ── 파일 저장 ─────────────────────────────────────────────────────────────────
# 다운로드된 영상 및 편집 결과물 저장 경로 (컨테이너 내부 경로)
MEDIA_STORAGE_PATH=./media

# Instagram 업로드를 위한 공개 접근 가능한 미디어 URL
# 로컬 개발: http://localhost:8000/media
# 프로덕션: CDN/S3 URL (예: https://cdn.example.com/media)
MEDIA_PUBLIC_BASE_URL=http://localhost:8000/media

# ── SNS: Instagram (Meta Graph API) ───────────────────────────────────────────
# Meta for Developers 앱 대시보드에서 발급
# 참고: https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=

# Instagram 그래프 API 액세스 토큰 (60일 만료, 장기 토큰 발급 권장)
META_ACCESS_TOKEN=

# Instagram 비즈니스 계정 사용자 ID
# 확인: GET https://graph.facebook.com/me?fields=id&access_token=YOUR_TOKEN
META_INSTAGRAM_USER_ID=

# ── SNS: YouTube (Data API v3) ────────────────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보
# 참고: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# YouTube OAuth2 리프레시 토큰 (만료 없음)
# 발급: https://developers.google.com/youtube/v3/guides/auth/server-side-web-apps
YOUTUBE_REFRESH_TOKEN=

# ── SNS: TikTok (Content Posting API v2) ─────────────────────────────────────
# TikTok for Developers 앱 관리에서 발급
# 참고: https://developers.tiktok.com/apps/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# TikTok OAuth2 액세스 토큰
TIKTOK_ACCESS_TOKEN=

# ── 알림: Telegram Bot ────────────────────────────────────────────────────────
# @BotFather 에서 봇 생성 후 토큰 발급
TELEGRAM_BOT_TOKEN=

# 알림을 받을 채팅 ID (개인/그룹/채널)
# @userinfobot 으로 자신의 ID 확인 가능
TELEGRAM_CHAT_ID=
